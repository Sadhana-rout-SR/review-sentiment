# Optional but recommended for official Google review fetch
GOOGLE_PLACES_API_KEY=

# Optional: Meta Graph API token (required for official Facebook/Instagram comments)
FB_GRAPH_ACCESS_TOKEN=

# Optional: Use when collecting from specific Facebook/Instagram objects
FB_POST_ID=
IG_MEDIA_ID=

# Server-side cap for max_reviews requested from UI
MAX_ALLOWED_REVIEWS=300

# Database connection string (default sqlite file)
DATABASE_URL=sqlite:///sentilytics.db

# Example MySQL connection string:
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/sentilytics

# Soft time budget per analysis request
ANALYZE_TIME_BUDGET_SECONDS=55

# Scraper-level time budget for browser-based extraction
SCRAPE_TIME_BUDGET_SECONDS=45

# Keep TRUE to return only verified sources (Google API/Maps/social APIs)
# Set FALSE only if you explicitly want website scraping fallback.
REAL_REVIEW_ONLY=false
